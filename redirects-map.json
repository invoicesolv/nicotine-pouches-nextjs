  "patterns": {
    "description": "Pattern-based redirects for dynamic URL matching",
    "rules": [
      {
        "pattern": "^/us/product/(on|nic-s|sesh)-[^/]+$",
        "destination": "/us/compare",
        "description": "US discontinued product variants"
      },
      {
        "pattern": "^/product/(chainpop|vampyou|77|hit|niccos|pablo|kurwa)-[^/]+$",
        "destination": "/compare",
        "description": "UK discontinued product variants"
      },
      {
        "pattern": "^/brand/(vampyou|sesh\\+)$",
        "destination": "/brand/on",
        "description": "Discontinued brand pages"
      },
      {
        "pattern": "^/us/brand/(vampyou|sesh\\+)$",
        "destination": "/us/brand/on",
        "description": "US discontinued brand pages"
      }
    ]
  }

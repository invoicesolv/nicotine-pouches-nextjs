{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "domains": [
    "nicotine-pouches.org",
    "www.nicotine-pouches.org"
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.nicotine-pouches.org"
        }
      ],
      "destination": "https://nicotine-pouches.org/$1",
      "permanent": true
    }
  ]
}
